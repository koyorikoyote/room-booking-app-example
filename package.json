{
  "name": "room-booking-app",
  "version": "1.0.0",
  "description": "Room Booking Application with React + Express SSR",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgMagenta.bold\" --names \"SERVER,CLIENT\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:fresh": "npm run prisma:generate:safe && npm run dev",
    "dev:server": "npm run prisma:generate:safe && cross-env TS_NODE_TRANSPILE_ONLY=1 PORT=3002 NODE_ENV=development nodemon --exec \"ts-node --transpile-only --project tsconfig.server.json -r tsconfig-paths/register src/server/index.ts\"",
    "dev:client": "cross-env NODE_ENV=development webpack serve --config webpack.dev.js --port 3003",
    "postinstall": "npm run prisma:generate:safe",
    "prebuild": "npm run prisma:generate:safe",
    "build": "npm run build:client && npm run build:server",
    "build:client": "webpack --config webpack.prod.js",
    "build:server": "webpack --config webpack.server.js --mode production",
    "start": "node dist/server/index.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:generate:safe": "prisma generate || echo 'Prisma generate skipped'",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio --port 5556",
    "prisma:reset": "prisma migrate reset --force",
    "diagnostics": "ts-node --project tsconfig.server.json src/server/diagnostics.ts"
  },
  "keywords": [
    "react",
    "express",
    "ssr",
    "typescript",
    "booking"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "i18next": "^25.5.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.553.0",
    "mysql2": "^3.15.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.2.0",
    "react-native-web": "^0.21.2",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "zod": "^4.1.12"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.server.json -r tsconfig-paths/register prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@swc/core": "^1.15.1",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "html-webpack-plugin": "^5.6.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "mini-css-extract-plugin": "^2.9.4",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "prisma": "^6.19.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
